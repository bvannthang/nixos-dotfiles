general {
    colors = true
    interval = 5
}

order += "ethernet _first_"
order += "disk /"
order += "memory"
order += "tztime local"

ethernet _first_ {
    format_up = "E: %ip"
    format_down = "E: down"
}

disk "/" {
    format = "/ %free"
}

memory {
    format = "RAM %used / %total"
    threshold_degraded = "10%"
}

tztime local {
    format = "%Y-%m-%d %H:%M"
}
